{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "AI Service",
      "type": "shell",
      "command": "$env:PYTHONIOENCODING='utf-8'; & '.venv\\Scripts\\uvicorn.exe' main:app --port 8001",
      "options": {
        "cwd": "${workspaceFolder}/ai-service"
      },
      "presentation": {
        "group": "run",
        "panel": "dedicated",
        "reveal": "always"
      },
      "isBackground": true,
      "problemMatcher": []
    },
    {
      "label": "Backend",
      "type": "shell",
      "command": "npm run dev",
      "options": {
        "cwd": "${workspaceFolder}/backend"
      },
      "presentation": {
        "group": "run",
        "panel": "dedicated",
        "reveal": "always"
      },
      "isBackground": true,
      "problemMatcher": []
    },
    {
      "label": "Frontend",
      "type": "shell",
      "command": "npm run dev",
      "options": {
        "cwd": "${workspaceFolder}/frontend"
      },
      "presentation": {
        "group": "run",
        "panel": "dedicated",
        "reveal": "always"
      },
      "isBackground": true,
      "problemMatcher": []
    },
    {
      "label": "Run All",
      "dependsOn": ["AI Service", "Backend", "Frontend"],
      "dependsOrder": "parallel",
      "problemMatcher": [],
      "group": {
        "kind": "build",
        "isDefault": true
      }
    }
  ]
}
